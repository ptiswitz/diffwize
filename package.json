{
  "name": "diffwise",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered Git diff explainer",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/**/src/**/*.ts",
    "format": "prettier --write packages/**/src/**/*.ts",
    "format:check": "prettier --check packages/**/src/**/*.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "consola": "^3.2.3",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.6"
  }
}
