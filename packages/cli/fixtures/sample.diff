--- /dev/null
+++ b/packages/core/src/token-estimator.ts
@@ -0,0 +1,26 @@
+import type { DiffDocument } from './diff-parser.js'
+
+const CHARS_PER_TOKEN = 4
+
+export function estimateTokens(text: string): number {
+  return Math.ceil(text.length / CHARS_PER_TOKEN)
+}
+
+export function estimateDocumentTokens(doc: DiffDocument): number {
+  return doc.files.reduce((total, file) => {
+    const header = `--- ${file.path} (${file.status}) ---`
+    const hunks = file.hunks.map((h) => [h.header, ...h.lines].join('\n')).join('\n')
+    return total + estimateTokens(header + '\n' + hunks)
+  }, 0)
+}
+
+export type TokenBudget = {
+  estimated: number
+  budget: number
+  isOverBudget: boolean
+}
+
+export function checkTokenBudget(doc: DiffDocument, budget: number): TokenBudget {
+  const estimated = estimateDocumentTokens(doc)
+  return { estimated, budget, isOverBudget: estimated > budget }
+}
