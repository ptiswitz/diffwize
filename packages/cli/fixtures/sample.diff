+export function diffStats(doc: DiffDocument): string {
+  const renamedCount = doc.files.filter((f) => f.status === 'renamed').length
+  const parts: string[] = [`${doc.files.length} file(s) changed`]
+  if (doc.totalAdditions > 0) parts.push(`+${doc.totalAdditions}`)
+  if (doc.totalDeletions > 0) parts.push(`-${doc.totalDeletions}`)
+  if (renamedCount > 0) parts.push(`${renamedCount} renamed`)
+  return parts.join(', ')
+}
